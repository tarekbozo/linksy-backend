generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 String              @id @default(uuid())
  email              String              @unique
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  role               Role                @default(USER)
  isActive           Boolean             @default(true)
  onboarded          Boolean             @default(false)
  accounts           Account[]
  actorLogs          AuditLog[]          @relation("ActorAuditLogs")
  auditLogs          AuditLog[]          @relation("UserAuditLogs")
  chats              ChatMessage[]
  conversations      Conversation[]
  creditTransactions CreditTransaction[]
  freeDailyCredit    FreeDailyCredit?
  generatedImages    GeneratedImage[]
  magicTokens        MagicToken[]
  confirmedOrders    Order[]             @relation("ConfirmedByOrders")
  orders             Order[]             @relation("UserOrders")
  sessions           Session[]
  usageLogs          UsageLog[]
  creditBuckets      UserCredit[]
  subscription       UserSubscription?

  @@index([email])
  @@index([role])
}

model MagicToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model Session {
  id         String    @id @default(cuid())
  userId     String
  tokenHash  String    @unique
  userAgent  String?
  ipAddress  String?
  revokedAt  DateTime?
  expiresAt  DateTime
  createdAt  DateTime  @default(now())
  lastUsedAt DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
}

model Account {
  id                String   @id @default(cuid())
  userId            String
  provider          String
  providerAccountId String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model WaitlistEntry {
  id           String   @id @default(uuid())
  email        String   @unique
  status       String   @default("PENDING")
  source       String?
  locale       String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  referralCode String?  @unique
  referredBy   String?
}

model Conversation {
  id                 String              @id @default(cuid())
  userId             String
  title              String              @default("New conversation")
  provider           AiProvider          @default(ANTHROPIC)
  model              String              @default("claude-haiku-4-5-20251001")
  isInternal         Boolean             @default(false)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  messages           ChatMessage[]
  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  creditTransactions CreditTransaction[]

  @@index([userId, updatedAt])
}

model ChatMessage {
  id             String       @id @default(cuid())
  userId         String?
  role           String
  content        String
  model          String?
  createdAt      DateTime     @default(now())
  tokens         Int          @default(0)
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User?        @relation(fields: [userId], references: [id])

  @@index([conversationId, createdAt])
}

model GeneratedImage {
  id         String   @id @default(cuid())
  userId     String
  prompt     String
  model      String   @default("imagen-4.0-generate-001")
  createdAt  DateTime @default(now())
  isOverride Boolean  @default(false)
  tier       String   @default("HIGH")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model UsageLog {
  id        String    @id @default(cuid())
  userId    String
  type      UsageType
  model     String?
  tokens    Int       @default(0)
  images    Int       @default(0)
  createdAt DateTime  @default(now())
  credits   Int       @default(0)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model UserCredit {
  id           String              @id @default(cuid())
  userId       String
  type         CreditType
  amount       Int
  remaining    Int
  expiresAt    DateTime?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  transactions CreditTransaction[]
  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([userId, type])
}

model CreditTransaction {
  id             String          @id @default(cuid())
  userId         String
  userCreditId   String?
  type           TransactionType
  action         ActionType
  amount         Int
  balanceAfter   Int
  conversationId String?
  metadata       Json?
  createdAt      DateTime        @default(now())
  conversation   Conversation?   @relation(fields: [conversationId], references: [id])
  userCredit     UserCredit?     @relation(fields: [userCreditId], references: [id])
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userCreditId])
  @@index([conversationId])
}

model UserSubscription {
  id          String    @id @default(cuid())
  userId      String    @unique
  plan        Plan      @default(FREE)
  activatedAt DateTime?
  expiresAt   DateTime?
  autoRenew   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TopUpPack {
  id        String   @id @default(cuid())
  nameAr    String
  nameEn    String
  priceSYP  Int
  credits   Int
  validDays Int      @default(90)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  orders    Order[]
}

model Order {
  id          String      @id @default(cuid())
  userId      String
  createdAt   DateTime    @default(now())
  confirmedAt DateTime?
  plan        Plan?
  updatedAt   DateTime    @updatedAt
  status      OrderStatus @default(PENDING)
  confirmedBy String?
  priceSYP    Int
  topUpPackId String?
  confirmer   User?       @relation("ConfirmedByOrders", fields: [confirmedBy], references: [id])
  topUpPack   TopUpPack?  @relation(fields: [topUpPackId], references: [id])
  user        User        @relation("UserOrders", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([topUpPackId])
  @@index([confirmedBy])
}

model FreeDailyCredit {
  id          String   @id @default(cuid())
  userId      String   @unique
  lastResetAt DateTime @default(now())
  usedToday   Int      @default(0)
  dailyCap    Int      @default(10)
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id        String      @id @default(cuid())
  userId    String?
  actorId   String?
  action    AuditAction
  metadata  Json?
  createdAt DateTime    @default(now())
  actor     User?       @relation("ActorAuditLogs", fields: [actorId], references: [id])
  user      User?       @relation("UserAuditLogs", fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([actorId, createdAt])
  @@index([action, createdAt])
}

enum Role {
  ADMIN
  AGENT
  USER
}

enum Plan {
  FREE
  STUDENT
  FREELANCER
  CREATOR
}

enum OrderStatus {
  PENDING
  CONFIRMED
  REJECTED
}

enum UsageType {
  CHAT
  IMAGE
  VOICE
  VIDEO
}

enum AiProvider {
  ANTHROPIC
  OPENAI
  GEMINI
}

enum AuditAction {
  MAGIC_LINK_REQUESTED
  MAGIC_LINK_VERIFIED
  OAUTH_LOGIN
  LOGOUT
  LOGOUT_ALL_SESSIONS
  SESSION_REVOKED
  TOKEN_REFRESHED
  ACCOUNT_LINKED
  ACCOUNT_CREATED
  EMAIL_CHANGED
  PASS_ACTIVATED
  PASS_CREATED
  ORDER_CONFIRMED
  ROLE_CHANGED
  USER_DEACTIVATED
  ORDER_REJECTED
  PLAN_ACTIVATED
  TOPUP_PURCHASED
  FREE_CREDITS_RESET
}

enum CreditType {
  SUBSCRIPTION
  TOPUP
  FREE_DAILY
}

enum TransactionType {
  DEBIT
  CREDIT
}

enum ActionType {
  BASIC_CHAT
  ADVANCED_CHAT
  IMAGE_GENERATION
  VOICE_GENERATION
  VIDEO_GENERATION
  PLAN_ACTIVATION
  TOPUP_PURCHASE
  FREE_DAILY_RESET
  REFUND
  STUDY
}
